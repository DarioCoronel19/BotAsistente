{
  "module": "correction",
  "name": "M3 - Corrección / Ajustes",
  "description": "Aplicación de correcciones y ajustes técnicos",
  "steps": [
    {
      "id": "start_correction",
      "message": "Iniciando proceso de corrección técnica.",
      "options": [
        {
          "label": "Iniciar Corrección",
          "value": "start",
          "next_module": "correction",
          "next_step": "apply_correction"
        }
      ]
    },
    {
      "id": "apply_correction",
      "message": "Aplicando corrección identificada en el diagnóstico...",
      "options": [
        {
          "label": "Aplicar Corrección",
          "value": "apply",
          "next_module": "correction",
          "next_step": "validate_config"
        }
      ]
    },
    {
      "id": "validate_config",
      "message": "Validando configuración aplicada...",
      "options": [
        {
          "label": "Validar",
          "value": "validate",
          "next_module": "correction",
          "next_step": "check_error_corrected"
        }
      ]
    },
    {
      "id": "check_error_corrected",
      "message": "¿El error ha sido corregido exitosamente?",
      "options": [
        {
          "label": "Sí, error corregido",
          "value": "yes",
          "next_module": "correction",
          "next_step": "generate_evidence"
        },
        {
          "label": "No, aún hay error",
          "value": "no",
          "next_module": "correction",
          "next_step": "adjust_parameters"
        }
      ]
    },
    {
      "id": "adjust_parameters",
      "message": "Ajustando parámetros de configuración. Por favor especifique los nuevos valores:",
      "options": [
        {
          "label": "Aplicar Ajustes",
          "value": "adjust",
          "next_module": "correction",
          "next_step": "retry_validation"
        }
      ]
    },
    {
      "id": "retry_validation",
      "message": "Re-validando después del ajuste de parámetros...",
      "options": [
        {
          "label": "Re-validar",
          "value": "retry",
          "next_module": "correction",
          "next_step": "check_error_corrected"
        }
      ]
    },
    {
      "id": "generate_evidence",
      "message": "Generando evidencia de la corrección aplicada...",
      "options": [
        {
          "label": "Generar Evidencia",
          "value": "generate",
          "next_module": "evidence",
          "next_step": "start_evidence"
        }
      ]
    }
  ]
}

